{:id       :isaac.agent.schema-ownership
 :version  "0.0.0"
 :builtin? true
 :factory  isaac.module.protocol/module
 :description "Test-only schema fragments so configurator ownership specs see snapshot-only entity collections on the server classpath."

 :isaac.config/schema
 {:crew      {:schema {:name           "crew table"
                       :type           :map
                       :snapshot-only? true
                       :key-spec       {:type :string}

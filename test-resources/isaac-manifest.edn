  :models    {:schema {:name           "model table"
                       :type           :map
                       :snapshot-only? true
                       :key-spec       {:type :string}
                       :value-spec     {:name :model :type :map :schema {}}}}
  :providers {:schema {:name           "provider table"
                       :type           :map
                       :snapshot-only? true
                       :key-spec       {:type :string}
                       :value-spec     {:name :provider :type :map :schema {}}}}}}
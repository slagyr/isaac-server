{:id                             :isaac.server
 :version                        "0.1.0"
 :builtin?                       true
 :factory                        isaac.server.module/create-module

 :berths                         {:isaac.server/route             {:description "HTTP routes. :path is a clout pattern (literal segments, :name params, * wildcards). :method is :get/:post/... or :* for any-method. Prefix matching is just a trailing wildcard in the path."
                                                                   :schema      {:type :seq
                                                                                 :spec {:type    :map
                                                                                        :factory isaac.server.routes/register-route-entry!
                                                                                        :schema  {:method  {:type :keyword :validations [:present?]}
                                                                                                  :path    {:type :string :validations [:present?]}
                                                                                                  :handler {:type :symbol :validations [:present?]}}}}}
                                  :isaac.server/tools             {:description "LLM tool factories."
                                                                   :schema      {:type       :map
                                                                                 :key-spec   {:type :keyword}
                                                                                 :value-spec {:type    :map
                                                                                              :factory isaac.tool.registry/register-tool-entry!
                                                                                              :schema  {:factory {:type :symbol :validations [:present?]}}}}}
                                  :isaac.server/llm-api           {:description "LLM API factories — adapters per provider API (messages, chat-completions, ollama, ...)."
                                                                   :schema      {:type       :map
                                                                                 :key-spec   {:type :keyword}
                                                                                 :value-spec {:type    :map
                                                                                              :factory isaac.llm.api.protocol/register-api-entry!
                                                                                              :schema  {:factory {:type :symbol :validations [:present?]}}}}}
                                  :isaac.server/slash-commands    {:description "Slash commands installed into the bridge slash registry."
                                                                   :schema      {:type       :map
                                                                                 :key-spec   {:type :keyword}
                                                                                 :value-spec {:type    :map
                                                                                              :factory isaac.slash.registry/register-slash-entry!
                                                                                              :schema  {:factory {:type :symbol :validations [:present?]}}}}}
                                  :isaac.server/hook              {:description "Event hooks installed into the hook registry. Per-entry factory resolves :factory and registers the returned spec via isaac.hooks/register-hook!."
                                                                   :schema      {:type       :map
                                                                                 :key-spec   {:type :keyword}
                                                                                 :value-spec {:type    :map
                                                                                              :factory isaac.hooks/register-hook-entry!
                                                                                              :schema  {:factory {:type :symbol :validations [:present?]}}}}}
                                  :isaac.server/provider-template {:description "Provider templates — partial provider configs that user-config :providers entries can inherit from via :type."
                                                                   :schema      {:type       :map
                                                                                 :key-spec   {:type :keyword}
                                                                                 :value-spec {:type   :map
                                                                                              :schema {:template {:type :map}}}}}
                                  :isaac.server/provider          {:description "Materialized LLM providers — instances usable by models. Manifest contributions are third-party modules shipping a ready-to-use provider; user-instantiated providers in the [:providers] config slot also count toward this berth (see `[:registered-in? :isaac.server/provider [:providers]]` use sites)."
                                                                   :schema      {:type       :map
                                                                                 :key-spec   {:type :keyword}
                                                                                 :value-spec {:type :map}}}
                                  :isaac.server/comm              {:description "Communication channels (Discord, iMessage, ACP, …). Manifest contributions name available impls and carry the impl's :namespace (whose load implements isaac.comm.factory/create for that :type) plus its :extra-schema (extension fields composed into [:comms] slots of that :type). User-instantiated comm slots in the [:comms] config slot also count toward this berth, so `[:registered-in? :isaac.server/comm [:comms]]` accepts both manifest impl ids (the common :type values) and slot ids."
                                                                   :schema      {:type       :map
                                                                                 :key-spec   {:type :keyword}
                                                                                 :value-spec {:type    :map
                                                                                              :schema  {:namespace     {:type :symbol :validations [:present?]}
                                                                                                        :extra-schema  {:type :schema-map}
                                                                                                        :configurable? {:type :boolean}}}}}}

 :isaac/cli                      {:auth     {:usage     "auth <subcommand> [options]"
                                             :summary   "Manage authentication credentials"
                                             :namespace isaac.llm.auth.cli}
                                  :config   {:usage     "config <subcommand> [options]"
                                             :summary   "Inspect and validate Isaac configuration"
                                             :namespace isaac.config.cli.command}
                                  :crew     {:usage     "crew"
                                             :summary   "List configured crew members"
                                             :namespace isaac.crew.cli}
                                  :hail     {:usage     "hail <subcommand> [options]"
                                             :summary   "Produce hail records"
                                             :namespace isaac.hail.cli}
                                  :prompt   {:usage     "prompt -m <message> [options]"
                                             :summary   "Run a single prompt turn and exit"
                                             :namespace isaac.bridge.prompt-cli}
                                  :logs     {:usage     "logs [options]"
                                             :summary   "Tail and colorize the Isaac log file"
                                             :namespace isaac.logs.cli}
                                  :server   {:usage     "server [options]"
                                             :summary   "Start the Isaac HTTP server"
                                             :namespace isaac.server.cli}
                                  :service  {:usage     "service [options] <subcommand>"
                                             :summary   "Manage Isaac as a background service"
                                             :namespace isaac.service.cli}
                                  :sessions {:usage     "sessions [options]"
                                             :summary   "List stored conversation sessions"
                                             :namespace isaac.session.cli}}

 :isaac.server/route             [{:method :post :path "/hail/send" :handler isaac.hail.http/handler}
                                  {:method :* :path "/hooks/*" :handler isaac.hooks/handler}]

 :isaac.server/llm-api           {:messages         {:factory isaac.llm.api.messages/make}
                                  :grover           {:factory isaac.llm.api.grover/make}
                                  :ollama           {:factory isaac.llm.api.ollama/make}
                                  :chat-completions {:factory isaac.llm.api.chat-completions/make}
                                  :responses        {:factory isaac.llm.api.responses/make}}

 :isaac.server/tools             {:edit          {:factory isaac.tool.builtin/edit-tool-factory}
                                  :exec          {:factory isaac.tool.builtin/exec-tool-factory}
                                  :glob          {:factory isaac.tool.builtin/glob-tool-factory}
                                  :grep          {:factory isaac.tool.builtin/grep-tool-factory}
                                  :hail-send     {:factory isaac.tool.hail/hail-send-tool-factory}
                                  :list_skills   {:factory isaac.tool.skill/list-skills-tool-factory}
                                  :load_skill    {:factory isaac.tool.skill/load-skill-tool-factory}
                                  :memory_get    {:factory isaac.tool.builtin/memory-get-tool-factory}
                                  :memory_search {:factory isaac.tool.builtin/memory-search-tool-factory}
                                  :memory_write  {:factory isaac.tool.builtin/memory-write-tool-factory}
                                  :read          {:factory isaac.tool.builtin/read-tool-factory}
                                  :session_info  {:factory isaac.tool.builtin/session-info-tool-factory}
                                  :session_model {:factory isaac.tool.builtin/session-model-tool-factory}
                                  :web_fetch     {:factory isaac.tool.builtin/web-fetch-tool-factory}
                                  :web_search    {:factory isaac.tool.builtin/web-search-tool-factory}
                                  :write         {:factory isaac.tool.builtin/write-tool-factory}}

 :isaac.server/provider-template {:anthropic {:template {:api      "messages"
                                                         :base-url "https://api.anthropic.com"
                                                         :auth     "api-key"}}
                                  :xai       {:template {:api      "chat-completions"
                                                         :base-url "https://api.x.ai/v1"
                                                         :auth     "api-key"}}
                                  :grover    {:template {:api  "grover"
                                                         :auth "none"}}
                                  :ollama    {:template {:api      "ollama"
                                                         :base-url "http://localhost:11434"
                                                         :auth     "none"}}
                                  :openai    {:template {:api      "chat-completions"
                                                         :base-url "https://api.openai.com/v1"
                                                         :auth     "api-key"}}
                                  :chatgpt   {:template {:api      "responses"
                                                         :base-url "https://chatgpt.com/backend-api/codex"
                                                         :auth     "oauth-device"}}}

 :isaac.server/slash-commands    {:crew   {:factory isaac.slash.builtin/crew-command}
                                  :cwd    {:factory isaac.slash.builtin/cwd-command}
                                  :effort {:factory isaac.slash.builtin/effort-command}
                                  :model  {:factory isaac.slash.builtin/model-command}
                                  :status {:factory isaac.slash.builtin/status-command}}

 :isaac.config/schema
 {:acp                  {:schema {:name        :acp
                                  :type        :map
                                  :description "Agent Communication Protocol configuration"
                                  :schema      {:proxy-max-reconnects         {:type        :int
                                                                               :description "Maximum reconnect attempts for ACP proxy"}
                                                :proxy-reconnect-delay-ms     {:type        :int
                                                                               :description "Base reconnect delay in milliseconds for ACP proxy"}
                                                :proxy-reconnect-max-delay-ms {:type        :int
                                                                               :description "Maximum reconnect delay in milliseconds for ACP proxy"}}}}

  :command-paths        {:schema {:type        :seq
                                  :description "Extra typed roots to scan for prepared commands"
                                  :spec        {:type :string}}}

  :comms                {:schema {:name        "comms table"
                                    :type        :map
                                    :description "Communication channel configurations (map of name -> comm config)"
                                    :key-spec    {:type :id}
                                    :value-spec  {:name           :comm
                                                  :type           :map
                                                  :factory        isaac.comm.factory/create!
                                                  :dynamic-schema {:berth :isaac.server/comm :path [:extra-schema]}
                                                  :schema         {:type {:type         :id
                                                                          :options-from :comms
                                                                          :description  "Manifest comm kind to instantiate"
                                                                          :validations  [[:registered-in? :isaac.server/comm [:comms]]]}
                                                                   :crew {:type        :id
                                                                          :description "Crew id this comm routes into"
                                                                          :validations [:crew-exists?]}}}}}

  :crew                 {:entity-dir         "crew"
                         :frontmatter?       true
                         :merge-root-entity? true
                         :companion          {:field :soul :mode :exclusive}
                         :schema             {:name           "crew table"
                                              :type           :map
                                              :snapshot-only? true
                                              :description    "Crew member configurations (map of id -> crew config)"
                                              :key-spec       {:type :string}
                                              :value-spec     {:name   :crew
                                                               :type   :map
                                                               :schema {:compaction        {:type   :map
                                                                                            :schema {:async?         {:type :boolean}
                                                                                                     :head           {:type        :double
                                                                                                                      :validations [[:percentage? "e.g. 0.3 for 30% of context-window"]]}
                                                                                                     :head-threshold {:type        :ignore
                                                                                                                      :description "Derived: head must stay below threshold"
                                                                                                                      :validations [[:less-than? :head :threshold]]}
                                                                                                     :strategy       {:type        :keyword
                                                                                                                      :validations [[:one-of? :rubberband :slinky]]}
                                                                                                     :threshold      {:type        :double
                                                                                                                      :validations [[:percentage? "e.g. 0.8 for 80% of context-window"]]}}}
                                                                        :context-mode      {:type        :keyword
                                                                                            :description "How much transcript history to replay each turn"
                                                                                            :validations [[:one-of? :full :reset]]}
                                                                        :cwd               {:type        :string
                                                                                            :description "Default workdir for new sessions on this crew"
                                                                                            :validations [:absolute-path?]}
                                                                        :effort            {:type        :int
                                                                                            :description "Effort level override for this crew member (0-10)"}
                                                                        :history-retention {:type        :keyword
                                                                                            :description "Transcript history retention policy for new sessions"
                                                                                            :validations [[:one-of? :prune :retain]]}
                                                                        :id                {:type        :id
                                                                                            :description "Crew member id; must match filename when present"}
                                                                        :max-in-flight     {:type        :int
                                                                                            :description "Maximum concurrent in-flight turns for this crew member"
                                                                                            :validations [:positive?]}
                                                                        :model             {:type        :id
                                                                                            :description "ID of the model this crew member uses."
                                                                                            :validations [:model-exists?]}
                                                                        :provider          {:type        :id
                                                                                            :description "Provider id for direct provider/model crews"
                                                                                            :validations [[:registered-in? :isaac.server/provider [:providers]]]}
                                                                        :soul              {:type        :string
                                                                                            :description "The personality of this crew member. Alternatively saved at config/crew/<id>.md"}
                                                                        :tags              {:type        :ignore
                                                                                            :set-type?   true
                                                                                            :description "Flat set of keyword tags for discovery and routing"
                                                                                            :validations [:keyword-set?]}
                                                                        :tools             {:name        :tools
                                                                                            :type        :map
                                                                                            :description "Tool configuration"
                                                                                            :schema      {:allow       {:type        :seq
                                                                                                                        :description "Allowed tool names"
                                                                                                                        :spec        {:type        :keyword
                                                                                                                                      :validations [[:registered-in? :isaac.server/tools]]}}
                                                                                                          :directories {:type        :seq
                                                                                                                        :description "Allowed directories; :cwd expands to session cwd, strings are absolute paths"
                                                                                                                        :spec        {:type        :ignore
                                                                                                                                      :validations [:cwd-or-path?]}}}}}}}}

  :cron                 {:entity-dir         "cron"
                         :frontmatter?       true
                         :merge-root-entity? true
                         :companion          {:field :prompt :mode :required}
                         :schema             {:name        "cron table"
                                              :type        :map
                                              :description "Cron job configurations (map of job name -> cron job config)"
                                              :key-spec    {:type :string}
                                              :value-spec  {:name        :cron-job
                                                            :type        :map
                                                            :description "Cron job configuration"
                                                            :schema      {:crew   {:type        :id
                                                                                   :description "Crew id to run the job as"
                                                                                   :validations [:crew-exists?]}
                                                                          :expr   {:type        :string
                                                                                   :description "5-field cron expression"}
                                                                          :prompt {:type        :string
                                                                                   :description "Prompt sent when the cron job fires"}}}}}

  :defaults             {:schema {:name        :defaults
                                  :type        :map
                                  :description "Default crew and model selections"
                                  :schema      {:compaction        {:type        :map
                                                                    :description "Default compaction policy for sessions"
                                                                    :schema      {:async?         {:type :boolean}
                                                                                  :head           {:type        :double
                                                                                                   :validations [[:percentage? "e.g. 0.3 for 30% of context-window"]]}
                                                                                  :head-threshold {:type        :ignore
                                                                                                   :description "Derived: head must stay below threshold"
                                                                                                   :validations [[:less-than? :head :threshold]]}
                                                                                  :strategy       {:type        :keyword
                                                                                                   :validations [[:one-of? :rubberband :slinky]]}
                                                                                  :threshold      {:type        :double
                                                                                                   :validations [[:percentage? "e.g. 0.8 for 80% of context-window"]]}}}
                                                :context-mode      {:type        :keyword
                                                                    :description "Default transcript replay mode for new turns"
                                                                    :validations [[:one-of? :full :reset]]}
                                                :crew              {:type        :id
                                                                    :default     "main"
                                                                    :description "Default crew member id"
                                                                    :validations [:crew-exists?]}
                                                :effort            {:type        :int
                                                                    :description "Default effort level (0-10) when not overridden by provider/model/crew/session"}
                                                :history-retention {:type        :keyword
                                                                    :description "Default transcript history retention policy for new sessions"
                                                                    :validations [[:one-of? :prune :retain]]}
                                                :model             {:type        :id
                                                                    :default     "llama"
                                                                    :description "Default model alias"
                                                                    :validations [:model-exists?]}}}}

  :gateway              {:schema {:name        :gateway
                                  :type        :map
                                  :description "Gateway server configuration (ACP WebSocket)"
                                  :schema      {:host {:type :string :description "Bind host"}
                                                :port {:type :int :description "Bind port"}}}}

  :hail                 {:entity-dir         "hail"
                         :merge-root-entity? true
                         :companion          {:field :prompt :mode :optional}
                         :schema             {:name           :hail
                                              :type           :map
                                              :snapshot-only? true
                                              :description    "Hail band declarations"
                                              :key-spec       {:type :string}
                                              :value-spec     {:name        :hail-band
                                                               :type        :map
                                                               :description "Hail band declaration"
                                                               :schema      {:addressing   {:type        :ignore
                                                                                            :description "Derived: bands must address crews or sessions"
                                                                                            :validations [[:requires-any? :crew :crew-tags :session :session-tags]]}
                                                                             :crew         {:type        :seq
                                                                                            :description "Explicit crew ids eligible for the band"
                                                                                            :spec        {:type :string}}
                                                                             :crew-tags    {:type        :seq
                                                                                            :description "Tags crews must carry"
                                                                                            :spec        {:type :keyword}}
                                                                             :prompt       {:type        :string
                                                                                            :description "Optional companion markdown prompt for the band"}
                                                                             :reach        {:type        :keyword
                                                                                            :description "How many listeners receive the hail"
                                                                                            :validations [[:one-of? :one :all]]}
                                                                             :session      {:type        :seq
                                                                                            :description "Explicit session ids eligible for the band"
                                                                                            :spec        {:type :string}}
                                                                             :session-tags {:type        :seq
                                                                                            :description "Tags sessions must carry"
                                                                                            :spec        {:type :keyword}}}}}}

  :hooks                {:entity-dir   "hooks"
                         :frontmatter? true
                         :companion    {:field :template :mode :required}
                         :schema       {:name        :hooks
                                        :type        :map
                                        :description "Webhook configuration"
                                        :key-spec    {:type :string}
                                        :value-spec  {:name        :hook
                                                      :type        :map
                                                      :description "Webhook receiver configuration"
                                                      :schema      {:crew        {:type        :id
                                                                                  :description "Crew id to run the hook as"
                                                                                  :validations [:crew-exists?]}
                                                                    :id          {:type        :id
                                                                                  :description "Hook id; must match filename when present"}
                                                                    :model       {:type        :id
                                                                                  :description "Optional model override for the hook session"
                                                                                  :validations [:model-exists?]}
                                                                    :session-key {:type        :string
                                                                                  :description "Session key to use for dispatched turns"}
                                                                    :template    {:type        :string
                                                                                  :description "Rendered message template for the hook body"}}}
                                        :schema      {:auth {:name        :hook-auth
                                                             :type        :map
                                                             :description "Retired webhook auth configuration"
                                                             :schema      {:token {:type        :string
                                                                                   :validations [[:retired? "use :server :auth :token"]]}}}}}}

  :models               {:entity-dir         "models"
                         :merge-root-entity? true
                         :schema             {:name           "model table"
                                              :type           :map
                                              :snapshot-only? true
                                              :description    "Model configurations (map of id -> model config)"
                                              :key-spec       {:type :string}
                                              :value-spec     {:name   :model
                                                               :type   :map
                                                               :schema {:allows-effort       {:type        :boolean
                                                                                              :description "Whether to attach :effort to requests for this model (default true)"}
                                                                        :compaction          {:type        :map
                                                                                              :description "Compaction policy override for this model"
                                                                                              :schema      {:async?         {:type :boolean}
                                                                                                            :head           {:type        :double
                                                                                                                             :validations [[:percentage? "e.g. 0.3 for 30% of context-window"]]}
                                                                                                            :head-threshold {:type        :ignore
                                                                                                                             :description "Derived: head must stay below threshold"
                                                                                                                             :validations [[:less-than? :head :threshold]]}
                                                                                                            :strategy       {:type        :keyword
                                                                                                                             :validations [[:one-of? :rubberband :slinky]]}
                                                                                                            :threshold      {:type        :double
                                                                                                                             :validations [[:percentage? "e.g. 0.8 for 80% of context-window"]]}}}
                                                                        :context-window      {:type        :int
                                                                                              :description "Context window size in tokens"}
                                                                        :effort              {:type        :int
                                                                                              :description "Effort level override for this model (0-10)"}
                                                                        :history-retention   {:type        :keyword
                                                                                              :description "Transcript history retention policy for sessions created against this model"
                                                                                              :validations [[:one-of? :prune :retain]]}
                                                                        :id                  {:type        :id
                                                                                              :description "Model alias; must match filename when present"}
                                                                        :model               {:type        :string
                                                                                              :description "Provider-specific model name or id"
                                                                                              :validations [:present?]
                                                                                              :required?   true}
                                                                        :provider            {:type        :id
                                                                                              :description "Provider alias"
                                                                                              :validations [:present? [:registered-in? :isaac.server/provider [:providers]]]
                                                                                              :required?   true}
                                                                        :think-mode          {:type        :keyword
                                                                                              :description "Ollama: how :effort is translated. :bool (default) → think true/false; :levels → \"low\"|\"medium\"|\"high\"."}
                                                                        :thinking-budget-max {:type        :int
                                                                                              :description "Anthropic: max thinking budget tokens at effort=10; scales linearly. Default 32000."}}}}}

  :prefer-entity-files  {:schema {:type        :boolean
                                  :default     false
                                  :description "Prefer crew/*.edn, models/*.edn, and providers/*.edn for new entities"}}

  :prompt-dir-names     {:schema {:type        :map
                                  :description "Directory-name to prompt-type mapping for prepared prompts"
                                  :key-spec    {:type :string}
                                  :value-spec  {:type :string}}}

  :prompt-paths         {:schema {:type        :seq
                                  :description "Extra roots to scan for prepared prompts"
                                  :spec        {:type :string}}}

  :providers            {:entity-dir         "providers"
                         :merge-root-entity? true
                         :schema             {:name           "provider table"
                                              :type           :map
                                              :snapshot-only? true
                                              :description    "Provider configurations (map of id -> provider config)"
                                              :key-spec       {:type :string}
                                              :value-spec     {:name           :provider
                                                               :type           :map
                                                               :dynamic-schema {:berth :isaac.server/provider-template :path [:schema]}
                                                               :schema {:name                       {:type        :string
                                                                                                     :description "Display name"}
                                                                        :type                       {:type        :id
                                                                                                     :description "Manifest provider id to inherit template from"
                                                                                                     :validations [[:registered-in? :isaac.server/provider-template]]}
                                                                        :api                        {:type        :id
                                                                                                     :description "Provider API adapter (e.g. \"anthropic\", \"ollama\")"
                                                                                                     :validations [[:registered-in? :isaac.server/llm-api]]}
                                                                        :api-key                    {:type        :string
                                                                                                     :description "API key"
                                                                                                     :validations [[:present-when? :auth "api-key"]]}
                                                                        :assistant-base-url         {:type        :string
                                                                                                     :description "Base URL for assistant endpoints"}
                                                                        :auth                       {:type        :string
                                                                                                     :description "Authentication mode (e.g. \"oauth-device\")"}
                                                                        :auth-key                   {:type        :string
                                                                                                     :description "Authentication key"}
                                                                        :base-url                   {:type        :string
                                                                                                     :description "API base URL"}
                                                                        :compaction                 {:type        :map
                                                                                                     :description "Compaction policy override for this provider"
                                                                                                     :schema      {:async?         {:type :boolean}
                                                                                                                   :head           {:type        :double
                                                                                                                                    :validations [[:percentage? "e.g. 0.3 for 30% of context-window"]]}
                                                                                                                   :head-threshold {:type        :ignore
                                                                                                                                    :description "Derived: head must stay below threshold"
                                                                                                                                    :validations [[:less-than? :head :threshold]]}
                                                                                                                   :strategy       {:type        :keyword
                                                                                                                                    :validations [[:one-of? :rubberband :slinky]]}
                                                                                                                   :threshold      {:type        :double
                                                                                                                                    :validations [[:percentage? "e.g. 0.8 for 80% of context-window"]]}}}
                                                                        :effort                     {:type        :int
                                                                                                     :description "Effort level for this provider (0-10)"}
                                                                        :headers                    {:type        :map
                                                                                                     :description "Extra HTTP headers to include in requests"
                                                                                                     :key-spec    {:type :string}
                                                                                                     :value-spec  {:type :string}}
                                                                        :history-retention          {:type        :keyword
                                                                                                     :description "Transcript history retention policy for sessions created against this provider"
                                                                                                     :validations [[:one-of? :prune :retain]]}
                                                                        :id                         {:type        :id
                                                                                                     :description "Provider id; must match filename when present"}
                                                                        :models                     {:type        :seq
                                                                                                     :description "Canonical model ids served by this provider"
                                                                                                     :spec        {:type :string}}
                                                                        :originator                 {:type        :string
                                                                                                     :description "X-Originator header value"}
                                                                        :response-format            {:type        :string
                                                                                                     :description "Response format hint"}
                                                                        :stream-supports-tool-calls {:type        :boolean
                                                                                                     :description "Whether streaming mode supports tool calls"}
                                                                        :supports-system-role       {:type        :boolean
